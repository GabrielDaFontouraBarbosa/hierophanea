# Copy this file to .env and fill in your database credentials
# Example: postgres://user:password@localhost:5432/mydb
DATABASE_URL=postgres://user:password@localhost:5432/mydb
PORT=5000
NODE_ENV=development

# Cloudinary: URL base das imagens (obrigatório para produção)
# Ex: https://res.cloudinary.com/SEU_CLOUD/image/upload/v1
# Se usou pasta no upload, inclua: .../upload/v1/hierophanea
VITE_ASSETS_BASE_URL=
